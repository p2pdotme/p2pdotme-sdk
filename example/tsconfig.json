{
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@p2pdotme/sdk/react": ["../src/react/index.ts"],
      "@p2pdotme/sdk/order-routing": ["../src/order-routing/index.ts"],
      "@p2pdotme/sdk/profile": ["../src/profile/index.ts"],
      "@p2pdotme/sdk/payload": ["../src/payload/index.ts"]
    }
  },
  "include": ["src"]
}
