{
  "name": "@p2pdotme/sdk",
  "version": "1.0.4",
  "description": "P2P.me SDK",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.1",
  "engines": {
    "bun": "1.3.1"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./order-routing": {
      "types": "./dist/order-routing.d.ts",
      "import": "./dist/order-routing.mjs",
      "require": "./dist/order-routing.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.cjs"
    },
    "./qr-parsers": {
      "types": "./dist/qr-parsers.d.ts",
      "import": "./dist/qr-parsers.mjs",
      "require": "./dist/qr-parsers.cjs"
    },
    "./fraud-engine": {
      "types": "./dist/fraud-engine.d.ts",
      "import": "./dist/fraud-engine.mjs",
      "require": "./dist/fraud-engine.cjs"
    },
    "./payload": {
      "types": "./dist/payload.d.ts",
      "import": "./dist/payload.mjs",
      "require": "./dist/payload.cjs"
    },
    "./profile": {
      "types": "./dist/profile.d.ts",
      "import": "./dist/profile.mjs",
      "require": "./dist/profile.cjs"
    },
    "./country": {
      "types": "./dist/country.d.ts",
      "import": "./dist/country.mjs",
      "require": "./dist/country.cjs"
    },
    "./zkkyc": {
      "types": "./dist/zkkyc.d.ts",
      "import": "./dist/zkkyc.mjs",
      "require": "./dist/zkkyc.cjs"
    }
  },
  "typesVersions": {
    "*": {
      ".": ["./dist/index.d.ts"],
      "order-routing": ["./dist/order-routing.d.ts"],
      "react": ["./dist/react.d.ts"],
      "qr-parsers": ["./dist/qr-parsers.d.ts"],
      "fraud-engine": ["./dist/fraud-engine.d.ts"],
      "payload": ["./dist/payload.d.ts"],
      "profile": ["./dist/profile.d.ts"],
      "country": ["./dist/country.d.ts"],
      "zkkyc": ["./dist/zkkyc.d.ts"]
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/p2pdotme/order-routing-sdk.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsup",
    "size": "bun run build && node -e \"const fs=require('fs'),path=require('path');const files=fs.readdirSync('dist').filter(f=>/\\.(mjs|cjs)$/.test(f)).sort();let total=0;for(const f of files){const s=fs.statSync(path.join('dist',f)).size;total+=s;console.log(f.padEnd(28),(s/1024).toFixed(1).padStart(8)+' KB')}console.log('-'.repeat(40));console.log('Total'.padEnd(28),(total/1024).toFixed(1).padStart(8)+' KB')\"",
    "dev": "tsup --watch",
    "lint": "bunx @biomejs/biome check src/",
    "lint:fix": "bunx @biomejs/biome check --write src/",
    "format": "bunx @biomejs/biome format --write src/",
    "test": "NODE_OPTIONS='--experimental-require-module' vitest run",
    "test:watch": "NODE_OPTIONS='--experimental-require-module' vitest",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "release": "bun run build && changeset publish",
    "prepare": "husky"
  },
  "dependencies": {
    "@fingerprintjs/fingerprintjs": "5.1.0",
    "@seontechnologies/seon-javascript-sdk": "6.10.2",
    "neverthrow": "8.2.0",
    "viem": "2.47.6",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@noble/ciphers": "1.3.0",
    "@noble/curves": "1.9.1",
    "@noble/hashes": "1.8.0",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "tsup": "8.5.1",
    "typescript": "5.8.3",
    "vitest": "4.1.2"
  },
  "peerDependencies": {
    "react": "18 || ^19",
    "@reclaimprotocol/js-sdk": "^4",
    "@zkpassport/sdk": "^0.12.4"
  },
  "peerDependenciesMeta": {
    "@reclaimprotocol/js-sdk": {
      "optional": true
    },
    "@zkpassport/sdk": {
      "optional": true
    }
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "bunx @biomejs/biome check --write",
      "bunx @biomejs/biome format --write"
    ]
  }
}
